    "## create a multiple file\n",
    "emp_list = [\"kaushik\", \"Rishav\", \"Arihant\", \"govind\"]\n",
    "for emp in emp_list:\n",
    "    with open(f\"{emp}.txt\",\"w\") as file:\n",
    "        file.write(f\"Welcome {emp}\")\n",
    "        \n",
    "print(\"All files created\")\n",
    "        \n",
